export default function WWITest() {
  const [answers, setAnswers] = useState({});
  const [submitted, setSubmitted] = useState(false);
  const [current, setCurrent] = useState(0);

  const handleSelect = (qIdx, optIdx) => {
    if (submitted) return;
    setAnswers(prev => ({ ...prev, [qIdx]: optIdx }));
  };

  const score = submitted
    ? questions.reduce((acc, q, i) => acc + (answers[i] === q.answer ? 1 : 0), 0)
    : 0;

  const grade = score >= 27 ? "5" : score >= 24 ? "4" : score >= 20 ? "3" : score >= 15 ? "2" : "1";

  const allAnswered = Object.keys(answers).length === questions.length;

  return (
    <div style={{
      minHeight: "100vh",
      background: "#1a0f00",
      backgroundImage: "repeating-linear-gradient(0deg, transparent, transparent 40px, rgba(139,90,43,0.05) 40px, rgba(139,90,43,0.05) 41px), repeating-linear-gradient(90deg, transparent, transparent 40px, rgba(139,90,43,0.05) 40px, rgba(139,90,43,0.05) 41px)",
      fontFamily: "'Georgia', serif",
      padding: "40px 20px",
      color: "#e8d5b0"
    }}>
      <div style={{ maxWidth: 820, margin: "0 auto" }}>

        {/* Header */}
        <div style={{ textAlign: "center", marginBottom: 48, borderBottom: "2px solid #8b5a2b", paddingBottom: 32 }}>
          <div style={{ fontSize: 11, letterSpacing: 6, color: "#a07840", textTransform: "uppercase", marginBottom: 12 }}>Advanced Placement History</div>
          <h1 style={{ fontSize: 38, fontWeight: "bold", color: "#f0c060", margin: "0 0 8px", textShadow: "0 2px 8px rgba(0,0,0,0.5)", letterSpacing: 2 }}>WORLD WAR I</h1>
          <div style={{ fontSize: 15, color: "#b08850", letterSpacing: 3 }}>THE GREAT WAR · 1914 – 1919</div>
          <div style={{ marginTop: 16, display: "flex", justifyContent: "center", gap: 32, fontSize: 13, color: "#907040" }}>
            <span>30 Questions</span><span>·</span><span>AP College Level</span><span>·</span>
            <span style={{ color: submitted ? (score >= 20 ? "#6fce7f" : "#e06060") : "#907040" }}>
              {submitted ? `Score: ${score}/30 (AP ${grade})` : `${Object.keys(answers).length}/30 answered`}
            </span>
          </div>
        </div>

        {/* Score Banner */}
        {submitted && (
          <div style={{
            background: score >= 20 ? "rgba(30,80,40,0.6)" : "rgba(80,20,20,0.6)",
            border: `1px solid ${score >= 20 ? "#4a9a5a" : "#9a4a4a"}`,
            borderRadius: 8, padding: "20px 28px", marginBottom: 40, textAlign: "center"
          }}>
            <div style={{ fontSize: 28, fontWeight: "bold", color: score >= 20 ? "#7de890" : "#e88080" }}>
              {score}/30 — AP Score: {grade}
            </div>
            <div style={{ fontSize: 13, color: "#c0a060", marginTop: 6 }}>
              {score >= 27 ? "Outstanding — college credit worthy performance" :
               score >= 24 ? "Excellent — strong command of WWI material" :
               score >= 20 ? "Solid — passing AP threshold" :
               score >= 15 ? "Needs work — review key events and treaties" :
               "Keep studying — revisit your notes and timeline"}
            </div>
          </div>
        )}

        {/* Questions */}
        {questions.map((q, i) => {
          const selected = answers[i];
          const isCorrect = submitted && selected === q.answer;
          const isWrong = submitted && selected !== undefined && selected !== q.answer;

          return (
            <div key={i} style={{
              marginBottom: 32,
              background: submitted
                ? isCorrect ? "rgba(20,60,30,0.4)" : isWrong ? "rgba(70,15,15,0.4)" : "rgba(30,20,10,0.4)"
                : "rgba(40,28,12,0.5)",
              border: `1px solid ${submitted ? isCorrect ? "#3a7a4a" : isWrong ? "#7a3a3a" : "#5a4020" : "#5a4020"}`,
              borderRadius: 8, padding: "24px 28px",
              transition: "all 0.3s"
            }}>
              <div style={{ display: "flex", gap: 14, marginBottom: 16 }}>
                <span style={{
                  minWidth: 28, height: 28, borderRadius: "50%",
                  background: submitted ? isCorrect ? "#2a6a3a" : isWrong ? "#6a2a2a" : "#3a2a10" : "#3a2a10",
                  border: `1px solid ${submitted ? isCorrect ? "#5a9a6a" : isWrong ? "#9a5a5a" : "#7a5a30" : "#7a5a30"}`,
                  display: "flex", alignItems: "center", justifyContent: "center",
                  fontSize: 12, color: "#c0a060", fontWeight: "bold", flexShrink: 0
                }}>{i + 1}</span>
                <p style={{ margin: 0, fontSize: 15.5, lineHeight: 1.6, color: "#ead8b0", fontWeight: "500" }}>{q.q}</p>
              </div>

              <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10, marginLeft: 42 }}>
                {q.options.map((opt, j) => {
                  const isSelected = selected === j;
                  const isAnswer = q.answer === j;
                  let bg = "rgba(60,40,15,0.4)";
                  let border = "1px solid #6a4a20";
                  let color = "#c8b080";
                  if (!submitted && isSelected) { bg = "rgba(120,80,20,0.5)"; border = "1px solid #c8902a"; color = "#f0d090"; }
                  if (submitted && isAnswer) { bg = "rgba(30,80,40,0.6)"; border = "1px solid #5a9a6a"; color = "#a0e8b0"; }
                  if (submitted && isSelected && !isAnswer) { bg = "rgba(80,20,20,0.6)"; border = "1px solid #9a5a5a"; color = "#e8a0a0"; }

                  return (
                    <button key={j} onClick={() => handleSelect(i, j)} style={{
                      background: bg, border, borderRadius: 6, padding: "10px 14px",
                      color, fontSize: 13.5, textAlign: "left", cursor: submitted ? "default" : "pointer",
                      transition: "all 0.15s", lineHeight: 1.4, fontFamily: "Georgia, serif"
                    }}>
                      <span style={{ opacity: 0.6, marginRight: 8, fontSize: 11 }}>{["A","B","C","D"][j]}.</span>{opt}
                    </button>
                  );
                })}
              </div>

              {submitted && (
                <div style={{
                  marginTop: 14, marginLeft: 42, padding: "10px 14px",
                  background: "rgba(20,15,5,0.5)", borderLeft: "3px solid #8b6a30",
                  borderRadius: "0 6px 6px 0", fontSize: 13, color: "#c0a870", lineHeight: 1.6
                }}>
                  <strong style={{ color: "#e0c080" }}>Explanation: </strong>{q.explanation}
                </div>
              )}
            </div>
          );
        })}

        {/* Submit */}
        {!submitted && (
          <div style={{ textAlign: "center", marginTop: 16 }}>
            <button onClick={() => setSubmitted(true)} disabled={!allAnswered} style={{
              background: allAnswered ? "linear-gradient(135deg, #9a6a20, #c89030)" : "#3a2a10",
              border: allAnswered ? "1px solid #e0a040" : "1px solid #4a3a20",
              color: allAnswered ? "#fff8e8" : "#6a5a40",
              padding: "14px 48px", fontSize: 15, fontFamily: "Georgia, serif",
              letterSpacing: 2, borderRadius: 6, cursor: allAnswered ? "pointer" : "not-allowed",
              textTransform: "uppercase", transition: "all 0.2s"
            }}>
              {allAnswered ? "Submit Examination" : `Answer All Questions (${30 - Object.keys(answers).length} remaining)`}
            </button>
          </div>
        )}

        {submitted && (
          <div style={{ textAlign: "center", marginTop: 24 }}>
            <button onClick={() => { setAnswers({}); setSubmitted(false); window.scrollTo(0,0); }} style={{
              background: "transparent", border: "1px solid #6a4a20", color: "#a07040",
              padding: "10px 32px", fontSize: 13, fontFamily: "Georgia, serif",
              letterSpacing: 2, borderRadius: 6, cursor: "pointer", textTransform: "uppercase"
            }}>Retake Test</button>
          </div>
        )}
      </div>
    </div>
  );
}
